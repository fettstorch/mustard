# Local-only secrets for `supabase functions serve` (NOT used by deployed functions).
# Copy this file to `.env` in the same directory and fill in the GitHub values:
#   cp supabase/functions/.env.example supabase/functions/.env
#
# `.env` is gitignored because it holds real GitHub OAuth client secrets.
# Production secrets are set separately via:
#   supabase secrets set JWT_SIGNING_SECRET=<Dashboard → Settings → API → JWT Secret>

# Fixed well-known default JWT secret of every local Supabase instance.
# Safe to commit — it only signs tokens for the local dev stack.
JWT_SIGNING_SECRET=super-secret-jwt-token-with-at-least-32-characters-long

# GitHub OAuth (only needed when testing GitHub connect locally).
# Get these from your GitHub OAuth apps (one per browser due to single redirect URI).
GITHUB_CLIENT_ID=your-chrome-oauth-app-client-id
GITHUB_CLIENT_SECRET=your-chrome-oauth-app-client-secret
GITHUB_CLIENT_ID_FIREFOX=your-firefox-oauth-app-client-id
GITHUB_CLIENT_SECRET_FIREFOX=your-firefox-oauth-app-client-secret
