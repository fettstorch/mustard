# Secrets for local edge function development (read by `supabase functions serve` only).
# This file has NO effect on deployed functions — production secrets are set via:
#   supabase secrets set JWT_SIGNING_SECRET=<value from Supabase Dashboard → Settings → API → JWT Secret>
#
# This value is safe to commit: it's the fixed well-known default JWT secret
# for every local Supabase instance (hardcoded in the Supabase CLI).
JWT_SIGNING_SECRET=super-secret-jwt-token-with-at-least-32-characters-long
