{
  "name": "mustard",
  "version": "2.3.0",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "scripts": {
    "dev": "wxt -b chrome --mode production",
    "dev:local": "wxt -b chrome",
    "dev:firefox": "wxt -b firefox --mode production",
    "dev:firefox:local": "wxt -b firefox",
    "setup:local": "open \"http://127.0.0.1:54323/project/default/editor/17746?schema=public\" && stmux -w always -- [ \"supabase start && supabase functions serve\" .. \"npm run dev:local\" ]",
    "build": "wxt build -b chrome",
    "build:firefox": "wxt build -b firefox",
    "build:e2e": "wxt build -b chrome",
    "zip": "wxt zip -b chrome",
    "zip:firefox": "wxt zip -b firefox",
    "type-check": "vue-tsc --build",
    "postinstall": "wxt prepare",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "lint": "oxlint .",
    "lint:fix": "oxlint . --fix",
    "lint:firefox": "addons-linter dist/firefox",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check": "npm run type-check && npm run lint && npm run format:check && npm run knip && npm run test && npm run build && npm run build:firefox && npm run lint:firefox"
  },
  "dependencies": {
    "@atproto/api": "^0.18.14",
    "@fettstorch/jule": "^3.0.0",
    "@supabase/supabase-js": "^2.97.0",
    "@tiptap/core": "^3.20.0",
    "@tiptap/extension-image": "^3.20.0",
    "@tiptap/extension-mention": "^3.23.1",
    "@tiptap/extensions": "^3.20.0",
    "@tiptap/markdown": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "@tiptap/suggestion": "^3.23.1",
    "@tiptap/vue-3": "^3.20.0",
    "markdown-it": "^14.1.1",
    "vue": "^3.5.26"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tsconfig/node24": "^24.0.3",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.10.4",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.8.1",
    "addons-linter": "^10.8.1",
    "knip": "^5.85.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "stmux": "^1.8.11",
    "typescript": "~5.9.3",
    "vite": "^8.0.11",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.2.1",
    "wxt": "^0.20.25"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
