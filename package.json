{
  "name": "mustard",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "wxt -b chrome --mode production",
    "dev:local": "wxt -b chrome",
    "dev:firefox": "wxt -b firefox",
    "setup:local": "open \"http://127.0.0.1:54323/project/default/editor/17746?schema=public\" && stmux -w always -- [ \"supabase start && supabase functions serve\" .. \"npm run dev:local\" ]",
    "build": "wxt build -b chrome",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip -b chrome",
    "zip:firefox": "wxt zip -b firefox",
    "type-check": "vue-tsc --build",
    "postinstall": "wxt prepare",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "lint": "eslint . --fix --cache",
    "format": "prettier --write --experimental-cli src/"
  },
  "dependencies": {
    "@atproto/api": "^0.18.14",
    "@fettstorch/jule": "^1.5.3",
    "@supabase/supabase-js": "^2.97.0",
    "@tiptap/core": "^3.20.0",
    "@tiptap/extension-image": "^3.20.0",
    "@tiptap/extensions": "^3.20.0",
    "@tiptap/markdown": "^3.20.0",
    "@tiptap/pm": "^3.20.0",
    "@tiptap/starter-kit": "^3.20.0",
    "@tiptap/vue-3": "^3.20.0",
    "markdown-it": "^14.1.1",
    "vue": "^3.5.26"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.3",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^24.10.4",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.6.0",
    "@vue/tsconfig": "^0.8.1",
    "eslint": "^9.39.2",
    "eslint-plugin-vue": "~10.6.2",
    "jiti": "^2.6.1",
    "knip": "^5.85.0",
    "prettier": "3.7.4",
    "stmux": "^1.8.11",
    "typescript": "~5.9.3",
    "vue-tsc": "^3.2.1",
    "wxt": "^0.20.25"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
